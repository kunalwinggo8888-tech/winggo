rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Wallets ───────────────────────────────────────────────────────────────
    match /wallets/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Transactions sub-collection
      match /transactions/{txId} {
        allow read:   if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // ── Deposits (admin-readable, user-creatable) ─────────────────────────────
    match /deposits/{depId} {
      allow read:   if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Withdraw Requests ─────────────────────────────────────────────────────
    match /withdrawRequests/{id} {
      allow read:   if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── KYC ───────────────────────────────────────────────────────────────────
    match /kycRequests/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Games (authenticated read, open write for seeding) ────────────────────
    match /games/{gameId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Leaderboards (authenticated read/write) ───────────────────────────────
    match /leaderboards/{gameType} {
      allow read: if request.auth != null;
      match /players/{uid} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Config (public read for app version / maintenance flags) ─────────────
    match /config/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{uid}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Referrals ─────────────────────────────────────────────────────────────
    match /referrals/{id} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
