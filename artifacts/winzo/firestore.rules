rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'staff'];
    }
    function notBanned() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
             !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false);
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create: if isOwner(uid) && notBanned();
      allow update: if isOwner(uid) && notBanned()
                    && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['kycStatus', 'banned', 'referralCode']);
      allow delete: if isAdmin();
    }

    // ── Wallets ──────────────────────────────────────────────────────────────
    match /wallets/{uid} {
      allow read:  if isSignedIn() && (isOwner(uid) || isAdmin());
      allow write: if isAdmin(); // All wallet mutations go through Cloud Functions or admin
    }

    match /wallets/{uid}/transactions/{txId} {
      allow read:   if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create: if isAdmin(); // Created server-side or via callable function
      allow update: if isAdmin();
      allow delete: if false;    // Transactions are immutable
    }

    // ── Withdraw Requests ────────────────────────────────────────────────────
    match /withdrawRequests/{requestId} {
      allow read:   if isSignedIn() && (
                      resource.data.uid == request.auth.uid || isAdmin()
                    );
      allow create: if isSignedIn() && notBanned()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.amount >= 100
                    && request.resource.data.amount <= 10000
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── KYC Requests ─────────────────────────────────────────────────────────
    match /kycRequests/{uid} {
      allow read:  if isSignedIn() && (isOwner(uid) || isAdmin());
      allow write: if isSignedIn() && isOwner(uid) && notBanned()
                   && (!exists(/databases/$(database)/documents/kycRequests/$(uid)) ||
                       resource.data.status == 'rejected');
      allow update: if isAdmin();
    }

    // ── Games Catalog ─────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read:   if true; // Public read
      allow write:  if isAdmin();
    }

    // ── App Config ───────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read:  if true; // Public read (maintenance mode, etc.)
      allow write: if isAdmin();
    }

    // ── Leaderboards ─────────────────────────────────────────────────────────
    match /leaderboards/{gameType} {
      allow read: if true;
      match /players/{uid} {
        allow read: if true;
        allow write: if isAdmin(); // Updated by Cloud Functions
      }
    }

    // ── Admins ───────────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read:  if isSignedIn() && (isOwner(uid) || isAdmin());
      allow write: if isAdmin() &&
                   get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{uid}/items/{notifId} {
      allow read:  if isSignedIn() && isOwner(uid);
      allow write: if isAdmin();
    }

    // ── Analytics (admin only) ────────────────────────────────────────────────
    match /analytics/{document=**} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── All Transactions log (admin only) ────────────────────────────────────
    match /allTransactions/{txId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
