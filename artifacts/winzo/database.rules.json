{
  "rules": {
    "presence": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "matchmaking": {
      "$gameType": {
        "$feeLevel": {
          "$roomId": {
            ".read":  "auth != null",
            ".write": "auth != null",
            "players": {
              "$uid": {
                ".write": "auth != null && (auth.uid === $uid || data.child('isBot').val() === true)"
              }
            }
          }
        }
      }
    },

    "rooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "gameState": {
          ".write": "auth != null"
        }
      }
    },

    "worldwar": {
      "$feeLevel": {
        "$roomId": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      }
    },

    "leaderboards": {
      "$gameType": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
